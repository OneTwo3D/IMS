# Copy to a real env file before use, for example:
#   cp scripts/provision-ims-tenant.env.example scripts/provision-ims-tenant.env
#   bash scripts/provision-ims-tenant.sh
#
# The provisioner auto-loads scripts/provision-ims-tenant.env when present.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
PROXMOX_HOST=proxmox.example.internal
PROXMOX_SSH_USER=root

PROXY_TYPE=ols
PROXY_HOST=proxy.example.internal
PROXY_SSH_USER=root
PROXY_PUBLIC_IP=203.0.113.10

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Optional. If blank, the provisioner asks Proxmox for the next available ID.
LXC_ID=
LXC_TEMPLATE=local:vztmpl/debian-12-standard_12.7-1_amd64.tar.zst
LXC_STORAGE=local-lvm

ADMIN_EMAIL=admin@example.com
NOTIFICATION_EMAIL=ops@example.com
LETSENCRYPT_EMAIL=ops@onetwoinventory.com

SMTP_HOST=smtp.postmarkapp.com
SMTP_FROM_EMAIL=ims@onetwoinventory.com

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
# If omitted, a unique funny slug like "milo-otter" is generated automatically.
TENANT_SLUG=
# Optional full domain override, e.g. ims.example.com
TENANT_DOMAIN=
DOMAIN_SUFFIX=onetwoinventory.com

ADMIN_NAME=IMS Admin
DEFAULT_ADMIN_PASSWORD=

SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls
SMTP_FROM_NAME=One Two Inventory
SMTP_REPLY_TO=support@onetwoinventory.com
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

GIT_REPO_URL=
GIT_BRANCH=main
DEPLOY_SOURCE_MODE=git
# Used only when DEPLOY_SOURCE_MODE=local. Leave blank to use the current repo checkout.
LOCAL_SOURCE_DIR=
# Requires a GitHub SSH repo URL above, for example: git@github.com:owner/repo.git
GIT_DEPLOY_KEY_ENABLED=n
GITHUB_DEPLOY_KEY_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
# Optional. Defaults to ims-<tenant-slug>-<lxc-id>.
GITHUB_DEPLOY_KEY_TITLE=

APP_PORT=3000
INSTALL_SSHD=n
SSH_AUTHORIZED_KEY=
RESUME_ONLY=n

# Defaults to TENANT_SLUG when blank.
LXC_HOSTNAME=
LXC_CORES=4
LXC_MEMORY_MB=4096
LXC_SWAP_MB=1024
LXC_DISK_GB=32
LXC_BRIDGE=vmbr0
LXC_IP_CIDR=
LXC_NET_GW=
LXC_NAMESERVER=1.1.1.1
LXC_PASSWORD=

POSTGRES_MODE=local
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_ADMIN_DATABASE=postgres
DB_ADMIN_USER=
DB_ADMIN_PASSWORD=

# disabled = do not configure Redis
# local = install redis-server inside the new LXC
# external = point IMS at an existing Redis server
REDIS_MODE=disabled
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Defaults to TENANT_SLUG when blank.
REDIS_KEY_PREFIX=

CLOUDFLARE_PROXIED=false

# OLS-specific
OLS_HOST=
OLS_SSH_USER=root
OLS_HTTP_LISTENER=Default
OLS_HTTPS_LISTENER=SSL

# nginx-specific
NGINX_HOST=
NGINX_SSH_USER=root
NGINX_PUBLIC_IP=
NGINX_SITES_AVAILABLE_DIR=/etc/nginx/sites-available
NGINX_SITES_ENABLED_DIR=/etc/nginx/sites-enabled

BACKEND_HEALTH_PATH=/login

WC_STORE_URL=
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
WC_WEBHOOK_SECRET=
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_API_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_COMPANY_ID=
