# =============================================================================
# onetwoInventory — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before starting the app.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------

# Full public URL of the app (no trailing slash)
NEXT_PUBLIC_APP_URL=https://ims.yourdomain.com

# Node environment: development | production
NODE_ENV=production

# Secret used to sign/encrypt Auth.js sessions (min 32 random chars)
# Generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_-base64_32

# 32-byte key used to encrypt secrets stored in the database.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_-base64_32

# Bearer token used to authorize internal cron endpoints.
# Generate with: openssl rand -hex 32
CRON_SECRET=CHANGE_ME_generate_with_openssl_rand_-hex_32

# Auth.js base URL (same as NEXT_PUBLIC_APP_URL)
AUTH_URL=https://ims.yourdomain.com

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------

# Full Postgres connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://imsuser:CHANGE_ME@localhost:5432/onetwoinventory

# -----------------------------------------------------------------------------
# WOOCOMMERCE
# -----------------------------------------------------------------------------

# WooCommerce store base URL (no trailing slash)
WC_STORE_URL=https://yourstore.com

# WooCommerce REST API consumer key & secret
# Generate at: WooCommerce → Settings → Advanced → REST API
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret used to verify incoming WooCommerce webhooks
# Set the same value in: WooCommerce → Settings → Advanced → Webhooks → Secret
WC_WEBHOOK_SECRET=CHANGE_ME_random_string

# WooCommerce order status that triggers sync into IMS (comma-separated)
# Default: processing. Other options: on-hold, completed
WC_SYNC_STATUSES=processing

# Webhook sync or polling? true = use webhooks, false = use polling interval
WC_USE_WEBHOOKS=true

# Polling interval in minutes (only used if WC_USE_WEBHOOKS=false)
WC_POLL_INTERVAL_MINUTES=5

# -----------------------------------------------------------------------------
# XERO (UK region)
# -----------------------------------------------------------------------------

# OAuth 2.0 credentials from Xero Developer Portal (app.xero.com)
XERO_CLIENT_ID=CHANGE_ME
XERO_CLIENT_SECRET=CHANGE_ME

# Xero tenant ID (organisation ID — retrieved after OAuth flow)
# Leave blank on first run; the app will populate this after connecting
XERO_TENANT_ID=

# Xero tokens are stored in the database. This legacy path is no longer used.
# XERO_TOKEN_PATH=/var/lib/onetwoinventory/xero-token.json

# -----------------------------------------------------------------------------
# FX RATES (frankfurter.dev — free, no API key required)
# -----------------------------------------------------------------------------

# Base currency for all internal calculations
FX_BASE_CURRENCY=GBP

# FX rates are fetched via cron job hitting /api/cron/fx-rates daily at 06:00

# -----------------------------------------------------------------------------
# SMTP (transactional email — PO/RFQ emails)
# -----------------------------------------------------------------------------

SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587

# Encryption: tls | ssl | none
SMTP_SECURE=tls

SMTP_USER=your@email.com
SMTP_PASSWORD=CHANGE_ME

# From address shown on outgoing emails
SMTP_FROM_EMAIL=ims@yourdomain.com
SMTP_FROM_NAME=onetwoInventory

# -----------------------------------------------------------------------------
# PDF GENERATION
# -----------------------------------------------------------------------------

# Directory to store generated PDFs temporarily before sending/download
# Must be writable by the app process
PDF_TEMP_DIR=/tmp/onetwoinventory/pdf

# Directory to store database backups locally before download/remote upload
BACKUP_DIR=/var/lib/onetwoinventory/backups

# -----------------------------------------------------------------------------
# FILE UPLOADS (CSV imports)
# -----------------------------------------------------------------------------

# Max upload size in MB
UPLOAD_MAX_SIZE_MB=10

# Temporary directory for uploads
UPLOAD_TEMP_DIR=/tmp/onetwoinventory/uploads

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Log format: json (production) | pretty (development)
LOG_FORMAT=json
