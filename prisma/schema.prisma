model ShoppingSyncLog {
  id           String                @id @default(cuid())
  connector    String                @default("woocommerce")
  direction    ShoppingSyncDirection
  status       ShoppingSyncStatus    @default(PENDING)
  entityType   String // "Product", "SalesOrder", "StockLevel"
  entityId     String?
  externalId   String?
  payload      Json?
  errorMessage String?
  syncedAt     DateTime?
  createdAt    DateTime              @default(now())

  // Polymorphic reference: use entityType + entityId for application-level lookups.
  // No FK constraints — entityId may point to Product or SalesOrder based on entityType.

  @@index([connector, entityType, entityId])
  @@index([connector, externalId, createdAt])
  @@map("shopping_sync_logs")
}

model ShoppingWebhookEvent {
  id              String    @id @default(cuid())
  connector       String
  resource        String
  /// Operator-facing delivery identifier from the source system. Idempotency
  /// uses connector/resource/body hash because external delivery ids can vary
  /// across retries or helper-plugin versions.
  externalEventId String?
  topic           String?
  payloadHash     String
  payloadJson     Json
  status          String
  attempts        Int       @default(0)
  nextAttemptAt   DateTime?
  processedAt     DateTime?
  lastError       String?
  receivedAt      DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([connector, resource, payloadHash], map: "shopping_webhook_events_connector_resource_payloadHash_key")
  @@index([connector, resource, status, receivedAt], map: "swhe_due_idx")
  @@index([connector, status, nextAttemptAt], map: "swhe_retry_idx")
  @@index([connector, externalEventId], map: "swhe_external_event_id_idx")
  @@map("shopping_webhook_events")
}

model StockSyncState {
  connector        String
  productId        String
  lastPushedQty    Int?
  lastPushedAt     DateTime?
  lastPushedRemoteId String?
  lastWebhookQty   Int?
  lastWebhookAt    DateTime?
  lastCorrectedAt  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([connector, productId])
  @@map("stock_sync_states")
}

model StockSyncJob {
  connector   String
  productId   String
  reason      StockSyncReason    @default(IMS_CHANGE)
  status      StockSyncJobStatus @default(PENDING)
  force       Boolean            @default(false)
  webhookQty  Int?
  attempts    Int                @default(0)
  lastError   String?
  availableAt DateTime           @default(now())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  product     Product            @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([connector, productId])
  @@index([connector, status, availableAt])
  @@map("stock_sync_jobs")
}

model IntegrationOutbox {
  id             String   @id @default(cuid())
  connector      String
  operation      String
  idempotencyKey String   @unique
  payloadJson    Json
  status         String
  attempts       Int      @default(0)
  nextAttemptAt  DateTime?
  lastError      String?
  lockedAt       DateTime?
  lockedBy       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([connector, operation, status, nextAttemptAt])
  @@index([lockedAt])
  @@map("integration_outbox")
}

