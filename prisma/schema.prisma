// ---------------------------------------------------------------------------
// WMS / WAREHOUSE CONNECTOR
// ---------------------------------------------------------------------------

enum WmsStockSyncMode {
  DISABLED
  NOTIFICATION_ONLY
  ALIGN_TO_WMS
}

enum WmsStockMasterSystem {
  IMS
  WMS
}

enum WmsBundleSyncDirection {
  DISABLED
  IMS_TO_WMS
  WMS_TO_IMS
}

enum WmsReturnsMode {
  DISABLED
  POLL
  WEBHOOK
}

enum WmsSyncJobType {
  STOCK_SYNC
  PRODUCT_SYNC
  BUNDLE_SYNC
  ASN_CREATE
  ASN_CALLBACK
  RETURNS_SYNC
  PRODUCT_VERIFY
}

enum WmsSyncJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL
}

enum WmsDiscrepancyCategory {
  MISSING_IN_IMS
  MISSING_IN_WMS
  QTY_MISMATCH
  UNMAPPED_SKU
  RECEIPT_TIMING_CONFLICT
  BUNDLE_DERIVATION_CONFLICT
  BARCODE_CONFLICT
  BARCODE_BACKFILLED_FROM_WMS
}

enum WmsDiscrepancyStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  IGNORED
}

enum WmsReturnsInboxStatus {
  NEW
  UNDER_REVIEW
  RESTOCKED
  QUARANTINED
  REFUNDED_ONLY
  REPLACED
  INSPECT
  DISMISSED
}

enum WmsAsnSourceType {
  PURCHASE_ORDER
  PURCHASE_ORDER_LINE
  STOCK_TRANSFER
  STOCK_TRANSFER_LINE
}

enum WmsAsnStatus {
  CREATE_PENDING
  CREATE_IN_FLIGHT
  OPEN
  PARTIALLY_BOOKED_IN
  BOOKED_IN
}

enum WmsSyncLogAction {
  created
  updated
  corrected
  noop
  sync
  backfill
  conflict
  skip
  discrepancy
  error
  asn_line_reconciled
  asn_line_mapped
}

model WmsConnection {
  id                   String   @id @default(cuid())
  connector            String
  label                String   @default("Primary")
  active               Boolean  @default(true)
  baseUrl              String?
  orderLookupConnector String?
  tokenExpiresAt       DateTime?
  lastAuthAt           DateTime?
  callbackSecretId     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  bindings             ExternalWmsBinding[]

  @@unique([connector, label])
  @@map("wms_connections")
}

model ExternalWmsBinding {
  id                   String                 @id @default(cuid())
  connectionId         String
  warehouseId          String
  connector            String
  externalWarehouseId  String
  active               Boolean                @default(true)
  stockSyncMode        WmsStockSyncMode       @default(NOTIFICATION_ONLY)
  stockMasterSystem    WmsStockMasterSystem   @default(IMS)
  bundleSyncDirection  WmsBundleSyncDirection @default(DISABLED)
  returnsMode          WmsReturnsMode         @default(DISABLED)
  syncFrequencyMinutes Int                    @default(60)
  discrepancyThresholds Json?
  reportRecipients     String[]               @default([])
  alignmentConfirmedAt DateTime?
  lastStockSyncAt      DateTime?
  lastStockSyncStatus  WmsSyncJobStatus?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  connection           WmsConnection          @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  warehouse            Warehouse              @relation(fields: [warehouseId], references: [id])

  @@unique([connector, warehouseId])
  @@unique([connector, externalWarehouseId])
  @@index([warehouseId])
  @@map("external_wms_bindings")
}

model WmsProductLink {
  id                String   @id @default(cuid())
  productId         String
  connector         String
  externalProductId String
  payloadHash       String?
  lastKnownBarcode  String?
  metadata          Json?
  lastSyncedAt      DateTime?
  lastError         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([connector, externalProductId])
  @@unique([connector, productId])
  @@index([productId])
  @@map("wms_product_links")
}

model WmsBundleLink {
  id               String   @id @default(cuid())
  productId        String
  connector        String
  externalBundleId String
  checksum         String?
  lastSyncedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([connector, externalBundleId])
  @@unique([connector, productId])
  @@index([productId])
  @@map("wms_bundle_links")
}

model WmsAsnMap {
  id             String   @id @default(cuid())
  connector      String
  externalAsnId  String
  sourceType     WmsAsnSourceType
  sourceId       String
  warehouseId    String
  status         WmsAsnStatus
  lastCallbackAt DateTime?
  closedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lines          WmsAsnLineMap[]
  warehouse      Warehouse @relation("WmsAsnMapWarehouse", fields: [warehouseId], references: [id], onDelete: Restrict)

  @@unique([connector, externalAsnId])
  @@index([sourceType, sourceId])
  @@map("wms_asn_maps")
}

model WmsAsnLineMap {
  id                     String    @id @default(cuid())
  asnMapId               String
  externalAsnLineId      String
  sourceType             WmsAsnSourceType
  sourceLineId           String
  productId              String
  sku                    String
  expectedQty            Decimal   @db.Decimal(12, 4)
  qtyAccountedViaSnapshot Decimal  @db.Decimal(12, 4) @default(0)
  qtyAccountedViaReceipt  Decimal  @db.Decimal(12, 4) @default(0)
  lastProcessedReceivedQty Decimal @db.Decimal(12, 4) @default(0)
  note                   String?
  lastCallbackAt         DateTime?
  createdAt              DateTime  @default(now())

  asn                    WmsAsnMap @relation(fields: [asnMapId], references: [id], onDelete: Cascade)
  product                Product   @relation("WmsAsnLineMapProduct", fields: [productId], references: [id], onDelete: Restrict)

  @@unique([asnMapId, externalAsnLineId])
  @@index([sourceType, sourceLineId])
  @@index([productId])
  @@map("wms_asn_line_maps")
}

model WmsSyncJob {
  id           String           @id @default(cuid())
  connector    String
  type         WmsSyncJobType
  status       WmsSyncJobStatus
  warehouseId  String?
  startedAt    DateTime
  finishedAt   DateTime?
  totalChecked Int              @default(0)
  matched      Int              @default(0)
  mismatched   Int              @default(0)
  corrected    Int              @default(0)
  skipped      Int              @default(0)
  errors       Int              @default(0)
  summary      Json?
  triggeredBy  String?
  createdAt    DateTime         @default(now())

  lines        WmsSyncLog[]
  warehouse    Warehouse?       @relation("WmsSyncJobWarehouse", fields: [warehouseId], references: [id], onDelete: SetNull)

  @@index([connector, type, status, startedAt])
  @@index([warehouseId, type, startedAt])
  @@map("wms_sync_jobs")
}

model WmsSyncLog {
  id           String     @id @default(cuid())
  jobId        String
  sku          String?
  productId    String?
  action       WmsSyncLogAction
  imsQtyBefore Decimal?   @db.Decimal(12, 4)
  imsQtyAfter  Decimal?   @db.Decimal(12, 4)
  wmsQty       Decimal?   @db.Decimal(12, 4)
  delta        Decimal?   @db.Decimal(12, 4)
  reason       String?
  payload      Json?
  createdAt    DateTime   @default(now())

  job          WmsSyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  product      Product?   @relation("WmsSyncLogProduct", fields: [productId], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@map("wms_sync_logs")
}

model WmsStockSnapshot {
  id           String   @id @default(cuid())
  connector    String
  warehouseId  String
  productId    String
  externalQty  Decimal  @db.Decimal(12, 4)
  imsQtyAtSync Decimal  @db.Decimal(12, 4)
  lastSeenAt   DateTime
  updatedAt    DateTime @updatedAt

  warehouse    Warehouse @relation("WmsStockSnapshotWarehouse", fields: [warehouseId], references: [id], onDelete: Cascade)
  product      Product   @relation("WmsStockSnapshotProduct", fields: [productId], references: [id], onDelete: Cascade)

  @@unique([connector, warehouseId, productId])
  @@index([warehouseId, productId])
  @@map("wms_stock_snapshots")
}

model WmsStockDiscrepancy {
  id             String               @id @default(cuid())
  connector      String
  warehouseId    String
  productId      String?
  sku            String?
  category       WmsDiscrepancyCategory
  /// Only one OPEN discrepancy per connector/warehouse/category/product-or-sku
  /// is allowed. This is enforced with partial unique SQL indexes because
  /// Prisma cannot express filtered uniqueness in the schema DSL.
  status         WmsDiscrepancyStatus @default(OPEN)
  imsValue       String?
  wmsValue       String?
  delta          Decimal?             @db.Decimal(12, 4)
  message        String?
  detectionCount Int                  @default(1)
  firstSeenAt    DateTime             @default(now())
  lastSeenAt     DateTime             @default(now())
  resolvedAt     DateTime?
  resolvedBy     String?
  resolvedNote   String?

  warehouse      Warehouse            @relation("WmsStockDiscrepancyWarehouse", fields: [warehouseId], references: [id], onDelete: Restrict)
  product        Product?             @relation("WmsStockDiscrepancyProduct", fields: [productId], references: [id], onDelete: SetNull)

  @@index([connector, status, category])
  @@index([warehouseId, status])
  @@index([productId])
  @@map("wms_stock_discrepancies")
}

model WmsInboundReceiptEvent {
  id                 String   @id @default(cuid())
  connector          String
  externalEventId    String
  externalAsnId      String?
  payload            Json
  processedAt        DateTime?
  processingStatus   String   @default("PENDING")
  processingAttempts Int      @default(0)
  nextRetryAt        DateTime?
  deadLetteredAt     DateTime?
  lastError          String?
  /// Full dry-run object captured when the event entered REQUIRES_REVIEW state.
  /// Stored as JSONB; dashboard queries show a capped event list and keep detailed inspection on the review API.
  reviewDetails      Json?
  /// Set only after an admin approval reprocesses the event successfully.
  /// Failed approval attempts remain visible in ActivityLog and lastError without stamping this field.
  reviewedAt         DateTime?
  /// User id of the approving admin. No FK so audit history survives user deletion.
  reviewedBy         String?
  receivedAt         DateTime @default(now())

  @@unique([connector, externalEventId])
  @@index([externalAsnId])
  @@index([processingStatus, nextRetryAt])
  @@index([deadLetteredAt])
  @@map("wms_inbound_receipt_events")
}

model WmsReturnsInbox {
  id               String                @id @default(cuid())
  connector        String
  externalReturnId String
  orderId          String?
  productId        String?
  sku              String?
  qty              Decimal?              @db.Decimal(12, 4)
  reason           String?
  reference        String?
  warehouseId      String?
  receivedAt       DateTime?
  status           WmsReturnsInboxStatus @default(NEW)
  rawPayload       Json?
  resolvedAt       DateTime?
  resolvedBy       String?
  resolutionNote   String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  order            SalesOrder?           @relation("WmsReturnsInboxOrder", fields: [orderId], references: [id], onDelete: SetNull)
  product          Product?              @relation("WmsReturnsInboxProduct", fields: [productId], references: [id], onDelete: SetNull)
  warehouse        Warehouse?            @relation("WmsReturnsInboxWarehouse", fields: [warehouseId], references: [id], onDelete: SetNull)

  @@unique([connector, externalReturnId])
  @@index([status, connector])
  @@map("wms_returns_inbox")
}

// ---------------------------------------------------------------------------
// ACTIVITY LOG
// ---------------------------------------------------------------------------

model ActivityLog {
  id          String             @id @default(cuid())
  userId      String?
  entityType  ActivityEntityType
  entityId    String?
  action      String             // e.g. "created", "updated", "deleted", "status_changed"
  tag         String             // human-friendly category: sales, purchase, inventory, stock, sync, settings, auth, import, manufacturing, system
  level       ActivityLogLevel   @default(INFO)
  description String             // human-readable clear text
  metadata    Json?              // diff or extra context
  createdAt   DateTime           @default(now())

  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([tag])
  @@index([level])
  @@index([level, createdAt])
  @@map("activity_logs")
}

model CronRun {
  id           String    @id @default(cuid())
  runId        String    @unique
  jobName      String
  startedAt    DateTime
  finishedAt   DateTime?
  durationMs   Int?
  status       String
  countsJson   Json?
  statusReason String?
  createdAt    DateTime  @default(now())

  @@index([jobName, startedAt])
  @@index([status, startedAt])
  @@map("cron_runs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?  // null = broadcast to all users
  type      String   // info | success | warning | error
  title     String
  message   String
  actionUrl String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  readAt    DateTime?

  user         User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  readReceipts NotificationReadReceipt[]

  @@index([userId, read, createdAt])
  @@map("notifications")
}

/// Per-user read receipt for notifications.
/// Broadcast notifications (userId=null) use this table so that marking them
/// read only affects the calling user, not everyone.
model NotificationReadReceipt {
  id             String   @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime @default(now())

  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId])
  @@map("notification_read_receipts")
}

model EmailOutbox {
  id                  String           @id @default(cuid())
  kind                String
  toEmail             String
  subject             String
  html                String
  attachments         Json?
  referenceType       String?
  referenceId         String?
  status              EmailOutboxStatus @default(PENDING)
  attempts            Int              @default(0)
  lastError           String?
  availableAt         DateTime         @default(now())
  processingStartedAt DateTime?
  sentAt              DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([status, availableAt])
  @@index([referenceType, referenceId])
  @@map("email_outbox")
}

model EmailSuppression {
  id         String   @id @default(cuid())
  email      String   @unique
  reason     String
  source     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastHitAt  DateTime @default(now())

  @@map("email_suppressions")
}

/// One-time auth tokens (TOTP challenge, passkey challenge, etc.)
/// Replaces the in-memory token store with a single-row lookup that survives
/// next start restarts.
model OneTimeToken {
  key       String   @id            // e.g. "passkey_challenge:...", "totp_verify:..."
  value     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("one_time_tokens")
}

// ---------------------------------------------------------------------------
// ORDER ALLOCATIONS & SHIPMENTS
// ---------------------------------------------------------------------------

/// Per-line warehouse allocation for sales orders
model OrderAllocation {
  id          String   @id @default(cuid())
  orderId     String
  lineId      String
  productId   String
  warehouseId String
  qty         Decimal  @db.Decimal(12, 4)
  costLayerSnapshot Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order       SalesOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  line        SalesOrderLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  product     Product        @relation(fields: [productId], references: [id])
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id])

  @@unique([lineId, warehouseId, productId])
  @@index([orderId])
  @@index([productId, warehouseId])
  @@index([costLayerSnapshot(ops: JsonbOps)], type: Gin, map: "order_allocations_costLayerSnapshot_gin_idx")
  @@map("order_allocations")
}

/// A shipment groups allocated lines from one warehouse
model Shipment {
  id              String         @id @default(cuid())
  orderId         String
  warehouseId     String
  status          ShipmentStatus @default(PENDING)
  trackingNumber  String?
  shippingService String?
  shippedAt       DateTime?

  // Accounting sub-ledger tracking
  shipmentJournalDate     DateTime?              @map("accounting_shipment_journal_date")
  cogsBatchAmount         Decimal?  @db.Decimal(18, 4) @map("accounting_cogs_batch_amount")
  revenueRecognizedAmount Decimal?  @db.Decimal(18, 4) @map("accounting_revenue_recognized_amount")

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  order           SalesOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  warehouse       Warehouse      @relation(fields: [warehouseId], references: [id])
  lines           ShipmentLine[]

  @@index([orderId])
  @@map("shipments")
}

/// Line items within a shipment
model ShipmentLine {
  id          String   @id @default(cuid())
  shipmentId  String
  lineId      String
  productId   String
  qty         Decimal  @db.Decimal(12, 4)
  costLayerSnapshot Json?

  shipment    Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  line        SalesOrderLine @relation(fields: [lineId], references: [id])
  product     Product        @relation(fields: [productId], references: [id])

  @@index([costLayerSnapshot(ops: JsonbOps)], type: Gin, map: "shipment_lines_costLayerSnapshot_gin_idx")
  @@map("shipment_lines")
}
