// onetwoInventory — Full Prisma Schema
// Prisma 7 · PostgreSQL · All modules

generator client {
  provider            = "prisma-client"
  output              = "../app/generated/prisma"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  MANAGER
  WAREHOUSE
  FINANCE
  READONLY
  SUPPLIER
}

enum ProductType {
  SIMPLE
  VARIABLE      // parent — not stockable itself
  VARIANT       // child of a VARIABLE parent
  KIT           // virtual bundle — stock calculated from components, deducted on sale
  BOM           // manufactured product — stock only exists after production run
  NON_INVENTORY // service / fee — unlimited, not tracked
}

enum ProductLifecycleStatus {
  ACTIVE
  NOT_FOR_SALE
  ARCHIVED
}

enum WarehouseType {
  STANDARD
  QUARANTINE
  RESTOCK
}

enum StockMovementType {
  PURCHASE_RECEIPT
  WMS_RECEIPT_RECONCILIATION
  SALE_DISPATCH
  RETURN_INBOUND
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT
  PURCHASE_REVERSAL
  PRODUCTION_IN
  PRODUCTION_OUT
  KIT_ASSEMBLY_IN
  KIT_ASSEMBLY_OUT
  OPENING_STOCK
}

enum PurchaseOrderStatus {
  DRAFT
  RFQ_SENT
  QUOTE_RECEIVED
  PO_SENT
  SHIPPED
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  INVOICED
  PARTIALLY_RETURNED
  RETURNED
  CANCELLED
}

enum PurchaseOrderType {
  GOODS      // primary PO for products
  FREIGHT    // secondary PO linked to goods PO (e.g. FedEx, customs)
}

enum LandedCostMethod {
  BY_VALUE
  BY_WEIGHT
  BY_QUANTITY
  EQUAL_SPLIT
}

enum SalesOrderStatus {
  DRAFT
  PENDING_PAYMENT
  ON_HOLD
  PROCESSING
  ALLOCATED
  PICKING
  PACKING
  SHIPPED
  COMPLETED
  DELIVERED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ShipmentStatus {
  PENDING
  PICKING
  PACKED
  SHIPPED
}

enum StockTransferStatus {
  DRAFT
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum StockCountStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProductionOrderType {
  ASSEMBLY
  DISASSEMBLY
}

enum ProductionOrderStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AccountingSyncType {
  PURCHASE_INVOICE
  COGS_JOURNAL
  INVENTORY_ADJUSTMENT
  SALES_INVOICE
  INVOICE_PAYMENT
  BILL_ATTACHMENT
  INVOICE_PDF
  INVOICE_EMAIL
  WC_INVOICE_NOTE
  CREDIT_NOTE
  STOCK_IN_TRANSIT
  STOCK_RECEIPT
  COGS_REVERSAL
  STOCK_ALLOCATION
  DAILY_BATCH_REVENUE_DEFERRAL
  DAILY_BATCH_INVENTORY_ALLOC
  DAILY_BATCH_GROUP_B
  UNEARNED_REV_REVERSAL
  BILL_PAYMENT
  REALISED_FX_JOURNAL
  UNREALISED_FX_JOURNAL
  MANUFACTURING_JOURNAL
  MANUFACTURING_RECLASS

  @@map("AccountingSyncType")
}

enum AccountingSyncStatus {
  PENDING
  PROCESSING
  SYNCED
  FAILED

  @@map("AccountingSyncStatus")
}

enum ShoppingSyncDirection {
  TO_CONNECTOR
  FROM_CONNECTOR
}

enum ShoppingSyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum StockSyncReason {
  IMS_CHANGE
  WC_WEBHOOK
  DAILY_RECONCILIATION
  MANUAL
}

enum StockSyncJobStatus {
  PENDING
  FAILED
}

enum ActivityEntityType {
  USER
  PRODUCT
  WAREHOUSE
  SUPPLIER
  CUSTOMER
  PURCHASE_ORDER
  SALES_ORDER
  STOCK_TRANSFER
  STOCK_COUNT
  STOCK_ADJUSTMENT
  PRODUCTION_ORDER
  SETTING
  IMPORT
  SYNC
  CURRENCY
  SYSTEM
  AccountingReconciliationFinding
}

enum ActivityLogLevel {
  INFO
  WARNING
  ERROR
}

enum EmailOutboxStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum TaxType {
  VAT
  GST
  NONE
}

enum TaxCategory {
  STANDARD
  REDUCED
  SECOND_REDUCED
  ZERO
  EXEMPT
}

enum CurrencyType {
  SALES
  PURCHASE
  BOTH
}

// ---------------------------------------------------------------------------
// AUTH & USERS
// ---------------------------------------------------------------------------

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  passwordHash   String
  role           UserRole  @default(ADMIN)
  supplierId     String?   // set when role=SUPPLIER — links to their company
  pictureUrl     String?
  totpSecret     String?   // null = 2FA not enabled
  pendingTotpSecret String? // staged secret during setup before confirmation
  totpEnabled    Boolean   @default(false)
  active         Boolean   @default(true)
  sessionVersion Int       @default(1)
  forceLogoutAt  DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  supplier       Supplier? @relation(fields: [supplierId], references: [id])
  activityLogs   ActivityLog[]
  notifications  Notification[]
  notificationReadReceipts NotificationReadReceipt[]
  sessions       Session[]
  passkeys       Passkey[]

  @@map("users")
}

model Passkey {
  id                  String   @id @default(cuid())
  userId              String
  credentialId        String   @unique
  credentialPublicKey Bytes
  counter             BigInt   @default(0)
  transports          String[] // e.g. ["usb", "ble", "nfc", "internal"]
  name                String   @default("Passkey")
  createdAt           DateTime @default(now())

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkeys")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// ORGANISATION & SETTINGS
// ---------------------------------------------------------------------------

model Organisation {
  id             String  @id @default(cuid())
  name           String
  legalName      String?
  vatNumber      String?
  companyNumber  String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  county         String?
  postcode       String?
  country        String  @default("GB")
  phone          String?
  email          String?
  website        String?
  logoUrl        String?   // square icon logo (sidebar, top-left)
  documentLogoUrl String?  // wide/rectangular logo for PDF document headers
  baseCurrency   String  @default("GBP")
  financialYearStartMonth Int @default(5) // May = 5
  financialYearStartDay   Int @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("organisations")
}

/// Generic key/value settings store for integration configs etc.
model Setting {
  key       String   @id
  value     String   // JSON-encoded string
  updatedAt DateTime @updatedAt

  @@map("settings")
}

/// Customisable document templates for PDF generation
model DocumentTemplate {
  id             String   @id @default(cuid())
  type           String   @unique // sales_order, purchase_order, invoice, packing_slip, credit_note, rfq
  headerNote     String?  // text above the table
  footerNote     String?  // text below the table
  termsText      String?  // terms & conditions
  customFooter   String?  // free text printed at the bottom of every page
  showLogo       Boolean  @default(true)
  showVat        Boolean  @default(true)
  showPaymentTerms Boolean @default(false)
  paymentTermsText String? // e.g. "Net 30 days"
  updatedAt      DateTime @updatedAt

  @@map("document_templates")
}

/// Configurable reasons for stock adjustments, each optionally linked to an accounting account.
/// accountCode is connector-agnostic: it is the account code in whichever accounting system
/// (Xero, QuickBooks, etc.) is currently active.
model AdjustmentReason {
  id              String   @id @default(cuid())
  name            String
  accountCode     String?  @map("account_code")
  sortOrder       Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("adjustment_reasons")
}

// ---------------------------------------------------------------------------
// CURRENCIES & FX
// ---------------------------------------------------------------------------

model Currency {
  code           String             @id // ISO 4217, e.g. "GBP"
  name           String
  symbol         String
  symbolPosition CurrencySymbolPos  @default(PREFIX) // "£23.99" vs "23.99 €"
  usedFor        CurrencyType       @default(BOTH)
  active         Boolean            @default(true)
  createdAt      DateTime           @default(now())

  fxRates        FxRate[]

  @@map("currencies")
}

enum CurrencySymbolPos {
  PREFIX
  POSTFIX
}

model FxRate {
  id             String   @id @default(cuid())
  fromCurrency   String   // always GBP (base)
  toCurrency     String
  rate           Decimal  @db.Decimal(18, 8) // 1 GBP = rate toCurrency
  fetchedAt      DateTime @default(now())
  /// Provenance of the rate. 'frankfurter' for ECB cron fetches, 'manual'
  /// when an admin pins a rate via the Currencies settings page. Lets the
  /// fetch loop skip override currencies and the UI badge them.
  source         String   @default("frankfurter")
  /// True when the row was inserted as a manual override. Stays true on the
  /// row forever; "clearing" the override means inserting a newer, non-
  /// override row that becomes the latest.
  manualOverride Boolean  @default(false)

  currency       Currency @relation(fields: [toCurrency], references: [code])

  @@index([toCurrency, fetchedAt])
  @@map("fx_rates")
}

/// Audit trail for outbound FX rate pushes from IMS to shopping connectors
/// (currently WooCommerce via the onetwoInventory Helper plugin). One row
/// per push attempt, success or failure. Surfaced on the Currencies
/// settings page so admins can see when a push last succeeded and whether
/// any errors occurred.
model FxRatePushLog {
  id           String   @id @default(cuid())
  connector    String   // 'woocommerce' | future: 'shopify' | etc.
  pushedAt     DateTime @default(now())
  ratesCount   Int
  status       String   // 'OK' | 'FAILED' | 'SKIPPED'
  errorMessage String?

  @@index([connector, pushedAt(sort: Desc)])
  @@map("fx_rate_push_log")
}

// ---------------------------------------------------------------------------
// TAX
// ---------------------------------------------------------------------------

model TaxRate {
  id          String      @id @default(cuid())
  name        String      // e.g. "UK Standard Rate"
  rate        Decimal     @db.Decimal(5, 4) // e.g. 0.2000 for 20%
  type        TaxType     @default(VAT)
  taxCategory TaxCategory @default(STANDARD)
  usedFor     String      @default("BOTH") // SALES, PURCHASE, BOTH
  accountingTaxType String?  @map("accounting_tax_type") // Accounting tax type code e.g. "OUTPUT2", "INPUT2"
  countryCode String?     // ISO 3166-1 alpha-2, null = applies globally
  active      Boolean     @default(true)
  isDefault   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  supplierTaxRate    Supplier[]
  orderLines         SalesOrderLine[]
  poLines            PurchaseOrderLine[]
  shoppingTaxRateMappings ShoppingTaxRateMapping[]

  @@index([countryCode, taxCategory, usedFor])
  @@map("tax_rates")
}

// ---------------------------------------------------------------------------
// WAREHOUSES
// ---------------------------------------------------------------------------

model Warehouse {
  id                    String        @id @default(cuid())
  code                  String        @unique // EAR2, CBG, RES, QUA
  name                  String
  type                  WarehouseType @default(STANDARD)
  availableForSale      Boolean       @default(true)
  syncToStore           Boolean       @default(false)
  contactName           String?
  email                 String?
  phone                 String?
  addressLine1          String?
  addressLine2          String?
  city                  String?
  postcode              String?
  country               String        @default("GB")
  isDefault             Boolean       @default(false)
  defaultReturnWarehouse Boolean      @default(false)
  active                Boolean       @default(true)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  stockLevels           StockLevel[]
  costLayers            CostLayer[]
  inventorySnapshots    InventorySnapshot[]
  inventoryReservationSnapshots InventoryReservationSnapshot[]
  transfersFrom         StockTransfer[] @relation("TransferFrom")
  transfersTo           StockTransfer[] @relation("TransferTo")
  stockCounts           StockCount[]
  movementsFrom         StockMovement[] @relation("MovementFromWarehouse")
  movementsTo           StockMovement[] @relation("MovementToWarehouse")
  productionOrders      ProductionOrder[]
  orderShipments        SalesOrder[]    @relation("ShipFromWarehouse")
  refundReturns         SalesOrderRefund[]
  incomingPurchaseOrders PurchaseOrder[] @relation("PODestinationWarehouse")
  orderAllocations      OrderAllocation[]
  shipments             Shipment[]
  wmsBindings           ExternalWmsBinding[]
  wmsAsnMaps            WmsAsnMap[]            @relation("WmsAsnMapWarehouse")
  wmsSyncJobs           WmsSyncJob[]           @relation("WmsSyncJobWarehouse")
  wmsStockSnapshots     WmsStockSnapshot[]     @relation("WmsStockSnapshotWarehouse")
  wmsStockDiscrepancies WmsStockDiscrepancy[]  @relation("WmsStockDiscrepancyWarehouse")
  wmsReturnsInbox       WmsReturnsInbox[]      @relation("WmsReturnsInboxWarehouse")

  @@map("warehouses")
}

// ---------------------------------------------------------------------------
// PRODUCTS
// ---------------------------------------------------------------------------

model Product {
  id              String      @id @default(cuid())
  sku             String      @unique
  name            String
  description     String?
  type            ProductType @default(SIMPLE)
  lifecycleStatus ProductLifecycleStatus @default(ACTIVE)
  categoryId      String?
  parentId        String?     // set for VARIANT products
  barcode         String?     @unique
  hsCode          String?
  countryOfOrigin String?     // 2-letter ISO code
  weight          Decimal?    @db.Decimal(10, 4) // kg, for landed cost by weight
  active          Boolean     @default(true)

  // Dimensions (cm)
  widthCm         Decimal?    @db.Decimal(10, 2)
  heightCm        Decimal?    @db.Decimal(10, 2)
  depthCm         Decimal?    @db.Decimal(10, 2)

  // Media
  imageUrl        String?     // primary image URL (can be imported from WooCommerce)

  // WooCommerce mapping — resolved once via SKU lookup then persisted for O(1) sync.
  // BigInt because WooCommerce/WordPress object IDs are unbounded by the
  // signed-32-bit range; a long-lived store can easily cross 2^31.
  externalProductId BigInt?   @unique

  // Pricing (GBP)
  salesPriceBase   Decimal?    @db.Decimal(12, 4)   // regular / list price
  salePriceBase    Decimal?    @db.Decimal(12, 4)   // sale / discounted price
  salesPriceTaxInclusive Boolean @default(false)

  // Tax
  taxCategory     TaxCategory @default(STANDARD)

  // Stock behaviour
  stockUnit       String      @default("pcs")       // display unit for stock levels, e.g. "pcs", "m", "kg"
  oversellAllowed Boolean     @default(true)        // continue selling when out of stock
  reorderPoint    Decimal?    @db.Decimal(12, 4)
  reorderQty      Decimal?    @db.Decimal(12, 4)
  safetyStockQty  Decimal?    @db.Decimal(12, 4)
  abcClass        String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  category        ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  parent          Product?    @relation("ProductVariants", fields: [parentId], references: [id])
  variants        Product[]   @relation("ProductVariants")

  stockLevels     StockLevel[]
  costLayers      CostLayer[]
  inventorySnapshots InventorySnapshot[]
  inventoryReservationSnapshots InventoryReservationSnapshot[]
  costLayerSourceLines CostLayerSourceLine[]
  stockMovements  StockMovement[]

  poLines         PurchaseOrderLine[]
  supplierProducts SupplierProduct[]

  salesOrderLines SalesOrderLine[]
  returnLines     SalesOrderRefundLine[]

  options         ProductOption[]

  // BOM (this product is the finished good)
  bomAsParent     BomItem[]   @relation("BomParent")
  // BOM (this product is a component)
  bomAsComponent  BomItem[]   @relation("BomComponent")

  // Kit items (this product is the kit)
  kitItems        KitItem[]   @relation("KitParent")
  // Kit items (this product is a component)
  kitItemsAsComponent KitItem[] @relation("KitItemComponent")

  // Product components: direct component list for KIT / BOM products
  productComponents     ProductComponent[] @relation("ProductHasComponents")
  usedAsComponentIn     ProductComponent[] @relation("ProductUsedAsComponent")

  productionOrdersAsOutput ProductionOrder[]

  orderAllocations OrderAllocation[]
  shipmentLines    ShipmentLine[]
  stockSyncStates  StockSyncState[]
  stockSyncJobs    StockSyncJob[]
  shoppingLinks    ShoppingProductLink[]
  wmsProductLinks  WmsProductLink[]
  wmsBundleLinks   WmsBundleLink[]
  wmsAsnLineMaps   WmsAsnLineMap[]       @relation("WmsAsnLineMapProduct")
  wmsSyncLogs      WmsSyncLog[]          @relation("WmsSyncLogProduct")
  wmsStockSnapshots WmsStockSnapshot[]   @relation("WmsStockSnapshotProduct")
  wmsStockDiscrepancies WmsStockDiscrepancy[] @relation("WmsStockDiscrepancyProduct")
  wmsReturnsInbox  WmsReturnsInbox[]     @relation("WmsReturnsInboxProduct")

  @@index([parentId])
  @@index([categoryId])
  @@map("products")
}

/// Product reporting category assigned to products for inventory and CSV reporting.
/// Categories are auto-created from product forms/imports and preserve the first
/// display spelling while matching future writes by normalized name.
model ProductCategory {
  id             String            @id @default(cuid())
  /// Operator-facing display name.
  name           String            @db.VarChar(100)
  /// Diacritic-insensitive normalized lookup key for case-insensitive matching.
  nameNormalized String            @unique @map("name_normalized") @db.VarChar(100)
  parentId       String?
  parent         ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children       ProductCategory[] @relation("ProductCategoryTree")
  products       Product[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([parentId])
  @@map("product_categories")
}

model ProductOption {
  id        String   @id @default(cuid())
  productId String
  name      String   // e.g. "Color", "Size"
  values    String   // comma-separated: "Red,Blue,Green"
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, name], map: "product_options_productId_name_key")
  @@index([productId])
  @@map("product_options")
}

/// Component list for KIT (virtual bundle) and BOM (manufactured) products
model ProductComponent {
  id            String   @id @default(cuid())
  productId     String   // the KIT or BOM product
  componentId   String   // component product
  qty           Decimal  @db.Decimal(12, 4)
  sortOrder     Int      @default(0)

  product       Product  @relation("ProductHasComponents", fields: [productId], references: [id], onDelete: Cascade)
  component     Product  @relation("ProductUsedAsComponent", fields: [componentId], references: [id])

  @@unique([productId, componentId])
  @@map("product_components")
}

// ---------------------------------------------------------------------------
// STOCK
// ---------------------------------------------------------------------------

model StockLevel {
  id              String    @id @default(cuid())
  productId       String
  warehouseId     String
  quantity        Decimal   @db.Decimal(12, 4) @default(0) // enforced non-negative in DB
  reservedQty     Decimal   @db.Decimal(12, 4) @default(0) // enforced non-negative in DB; in transit / allocated
  updatedAt       DateTime  @updatedAt

  product         Product   @relation(fields: [productId], references: [id])
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@map("stock_levels")
}

/// FIFO cost layers — one row per goods receipt (or opening stock seed)
model CostLayer {
  id              String    @id @default(cuid())
  productId       String
  warehouseId     String
  receivedQty     Decimal   @db.Decimal(12, 4) // enforced non-negative in DB
  remainingQty    Decimal   @db.Decimal(12, 4) // enforced non-negative in DB and <= receivedQty
  unitCostBase     Decimal   @db.Decimal(18, 6) // landed cost per unit in GBP
  receivedAt      DateTime  @default(now())
  poLineId        String?   // link back to the PO line that created this layer
  adjustmentMovementId String? @map("adjustment_movement_id")
  productionOrderId String?  @map("production_order_id")
  isOpeningStock  Boolean   @default(false)

  product         Product   @relation(fields: [productId], references: [id])
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  poLine          PurchaseOrderLine? @relation(fields: [poLineId], references: [id])
  adjustmentMovement StockMovement? @relation("AdjustmentMovementLayer", fields: [adjustmentMovementId], references: [id])
  productionOrder ProductionOrder? @relation(fields: [productionOrderId], references: [id], onDelete: SetNull)

  cogsEntries     CogsEntry[]
  sourceLines     CostLayerSourceLine[]

  @@index([productId, warehouseId, receivedAt])
  @@index([adjustmentMovementId])
  @@index([productionOrderId])
  @@map("cost_layers")
}

model CostLayerSourceLine {
  id                String    @id @default(cuid())
  costLayerId       String
  sourceProductId   String
  sourceCostLayerId String?
  qty               Decimal   @db.Decimal(12, 4)
  unitCostBase      Decimal   @db.Decimal(18, 6)
  totalCostBase     Decimal   @db.Decimal(18, 6)
  createdAt         DateTime  @default(now())

  costLayer         CostLayer @relation(fields: [costLayerId], references: [id], onDelete: Cascade)
  sourceProduct     Product   @relation(fields: [sourceProductId], references: [id])

  @@index([costLayerId])
  @@index([sourceProductId])
  @@index([sourceCostLayerId])
  @@map("cost_layer_source_lines")
}

/// Each COGS consumption event (sale, adjustment, etc.)
model CogsEntry {
  id            String            @id @default(cuid())
  costLayerId   String
  movementId    String
  qty           Decimal           @db.Decimal(12, 4)
  unitCostBase   Decimal           @db.Decimal(18, 6)
  totalCostBase  Decimal           @db.Decimal(18, 6)
  createdAt     DateTime          @default(now())

  costLayer     CostLayer         @relation(fields: [costLayerId], references: [id])
  movement      StockMovement     @relation(fields: [movementId], references: [id])

  @@map("cogs_entries")
}

/// Governed by additional db-native reporting guarantees from migration
/// 20260602103000_stock_movement_reporting_guarantees:
/// - value fields must both be null or both populated, and totalValueBase must
///   equal ROUND(qty * unitCostBase, 6)
/// - deferred evidence trigger requires inbound receipt/production/adjustment
///   movements to have cost-layer evidence and outbound dispatch/production/
///   adjustment movements to have COGS evidence by commit time
model StockMovement {
  id              String            @id @default(cuid())
  type            StockMovementType
  productId       String
  fromWarehouseId String?
  toWarehouseId   String?
  qty             Decimal           @db.Decimal(12, 4) // always positive; enforced non-negative in DB
  note            String?
  referenceType   String?           // e.g. "PurchaseOrder", "SalesOrder"
  referenceId     String?           // ID of the related entity
  /// Deterministic key for irreversible stock-movement flows. Null for legacy/manual rows.
  /// Keys are built by lib/domain/inventory/stock-movement-idempotency.ts.
  idempotencyKey  String?           @unique
  /// Reporting denormalization: unit cost in base currency at movement time.
  /// Null means historical source cost provenance was unavailable during backfill.
  /// Derivation: FIFO consumption for outbound, cost-layer or transfer snapshot for inbound, zero for historical demand imports.
  unitCostBase    Decimal?          @db.Decimal(18, 6)
  /// Reporting denormalization: total movement value in base currency.
  /// Expected to match qty * unitCostBase within inventory invariant tolerance.
  totalValueBase  Decimal?          @db.Decimal(18, 6)
  createdAt       DateTime          @default(now())

  product         Product           @relation(fields: [productId], references: [id])
  fromWarehouse   Warehouse?        @relation("MovementFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse?        @relation("MovementToWarehouse", fields: [toWarehouseId], references: [id])

  adjustmentLayers CostLayer[]      @relation("AdjustmentMovementLayer")
  cogsEntries     CogsEntry[]

  @@index([productId])
  @@index([createdAt])
  @@index([productId, createdAt])
  @@index([type, createdAt])
  @@index([referenceType, referenceId])
  @@map("stock_movements")
}

/// Per-migration stock movement value backfill audit. The id format is
/// <migration_name>:<movementType>:<reason> so multiple data migrations can
/// coexist; runAt updates on retry while firstRunAt preserves first occurrence.
model StockMovementBackfillAudit {
  id           String            @id
  movementType StockMovementType
  count        Int
  reason       String
  firstRunAt   DateTime          @default(now())
  runAt        DateTime          @default(now())

  @@map("stock_movement_backfill_audit")
}

/// Daily product/warehouse inventory position for reporting. Quantities come
/// from StockLevel; values come from open FIFO CostLayer rows at snapshot time.
/// Rows are sparse: absence for a product/warehouse/date means zero position.
/// Re-running a date is idempotent via the unique key and updates the captured
/// row in place. Drift between StockLevel quantity and FIFO-layer remaining
/// quantity is logged by the cron but snapshots still persist. These rows are
/// point-in-time captures, not live relations back to StockMovement/CostLayer.
model InventorySnapshot {
  id           String   @id @default(cuid())
  snapshotDate DateTime @db.Date
  productId    String
  warehouseId  String
  qty          Decimal  @db.Decimal(12, 4)
  valueBase    Decimal  @db.Decimal(18, 6)
  unitCostBase Decimal? @db.Decimal(18, 6)
  createdAt    DateTime @default(now())

  product      Product   @relation(fields: [productId], references: [id])
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([snapshotDate, productId, warehouseId])
  @@index([snapshotDate])
  @@index([productId, snapshotDate])
  @@index([warehouseId, snapshotDate])
  @@map("inventory_snapshots")
}

/// Daily product/warehouse reservation position for true as-of availability
/// reporting. Rows are captured from StockLevel.reservedQty and current
/// quantity at snapshot time, with reservationSourceCount recording the count
/// of distinct source rows behind the balance, not the reserved quantity sum.
/// A missing row means zero reserved only when InventoryReservationSnapshotRun
/// exists for that date. Re-running a date is idempotent via the unique key and
/// updates the captured row in place.
model InventoryReservationSnapshot {
  id                     String   @id @default(cuid())
  snapshotDate           DateTime @db.Date
  productId              String
  warehouseId            String
  reservedQty            Decimal  @db.Decimal(12, 4)
  availableQty           Decimal  @db.Decimal(12, 4)
  reservationSourceCount Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  product                Product   @relation(fields: [productId], references: [id])
  warehouse              Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([snapshotDate, productId, warehouseId], map: "inventory_reservation_snapshots_snapshotDate_productId_warehous")
  @@index([productId, snapshotDate])
  @@index([warehouseId, snapshotDate])
  @@map("inventory_reservation_snapshots")
}

/// Daily coverage marker for sparse InventoryReservationSnapshot rows. If a
/// run exists for a snapshotDate, absent product/warehouse rows represent zero
/// reserved quantity for that day. If no run exists, historical reports must
/// surface reservation evidence as missing instead of silently assuming zero.
model InventoryReservationSnapshotRun {
  id                       String   @id @default(cuid())
  snapshotDate             DateTime @unique @db.Date
  stockLevelCount          Int
  reservationSnapshotCount Int
  source                   String   @default("cron")
  checkMethod              String   @default("daily_current_state_v1")
  cutoffAt                 DateTime?
  reservationSourceCount   Int?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("inventory_reservation_snapshot_runs")
}

// ---------------------------------------------------------------------------
// SUPPLIERS
// ---------------------------------------------------------------------------

model Supplier {
  id              String    @id @default(cuid())
  name            String
  accountingContactId String?   @unique
  contactName     String?
  email           String?
  phone           String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  county          String?
  postcode        String?
  country         String?
  currency        String    @default("GBP")
  taxRateId       String?
  vatNumber       String?
  accountNumber   String?   // our account ref with supplier
  paymentTermsDays Int?
  /**
   * User-entered override for expected delivery time in days. Does NOT
   * overwrite the computed average — the average is always shown alongside
   * as read-only info in the supplier form.
   */
  manualDeliveryDays Int?
  notes           String?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  taxRate         TaxRate?  @relation(fields: [taxRateId], references: [id])
  purchaseOrders  PurchaseOrder[]
  supplierProducts SupplierProduct[]
  productionOrders ProductionOrder[]
  users           User[]

  @@map("suppliers")
}

/// Last known purchase price per supplier per product
model SupplierProduct {
  id              String    @id @default(cuid())
  supplierId      String
  productId       String
  supplierSku     String?   // supplier's own SKU/reference
  lastUnitCost    Decimal   @db.Decimal(18, 6)
  currency        String    // supplier's currency
  leadTimeDays    Int?
  updatedAt       DateTime  @updatedAt

  supplier        Supplier  @relation(fields: [supplierId], references: [id])
  product         Product   @relation(fields: [productId], references: [id])

  @@unique([supplierId, productId])
  @@map("supplier_products")
}

// ---------------------------------------------------------------------------
// PURCHASE ORDERS
// ---------------------------------------------------------------------------

model PurchaseOrder {
  id              String              @id @default(cuid())
  reference       String              @unique // e.g. PO-2024-0001
  type            PurchaseOrderType   @default(GOODS)
  supplierId      String
  status          PurchaseOrderStatus @default(DRAFT)
  currency        String              // PO currency
  fxRateToBase     Decimal             @db.Decimal(18, 8) // rate at time of creation
  subtotalForeign Decimal             @db.Decimal(18, 4)
  subtotalBase     Decimal             @db.Decimal(18, 4)
  taxRateName     String?             // e.g. "UK Standard Rate"
  taxRatePercent  Decimal?            @db.Decimal(5, 4) // e.g. 0.2000
  taxForeign      Decimal             @db.Decimal(18, 4) @default(0)
  taxBase          Decimal             @db.Decimal(18, 4) @default(0)
  totalForeign    Decimal             @db.Decimal(18, 4)
  totalBase        Decimal             @db.Decimal(18, 4)

  // Supplier direct freight/fees (in addition to linked freight POs)
  directFreightForeign Decimal        @db.Decimal(18, 4) @default(0)
  directFreightBase     Decimal        @db.Decimal(18, 4) @default(0)

  // Order-level discount (applied on top of any per-line discounts)
  discountStr      String?            // user input e.g. "10%" or "50.00"
  discountAmount   Decimal            @db.Decimal(18, 4) @default(0) // computed order discount in foreign currency, same tax convention as lines

  landedCostMethod LandedCostMethod  @default(BY_VALUE)

  destinationWarehouseId String?    // where goods will be received (can change before receipt)

  trackingNumber  String?
  shippingProvider String?

  notes           String?
  internalNotes   String?
  supplierRef     String?            // supplier's own PO/invoice reference
  expectedDelivery DateTime?
  receivedAt      DateTime?
  invoicedAt      DateTime?

  // Email tracking
  rfqSentAt       DateTime?
  poSentAt        DateTime?

  archived        Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  supplier             Supplier   @relation(fields: [supplierId], references: [id])
  destinationWarehouse Warehouse? @relation("PODestinationWarehouse", fields: [destinationWarehouseId], references: [id])
  lines           PurchaseOrderLine[]
  receipts        PurchaseReceipt[]
  invoices        PurchaseInvoice[]
  returns         PurchaseReturn[]

  // Landed cost links — this PO as primary
  landedCostLinks LandedCostLink[]   @relation("PrimaryPO")
  // This PO as freight/secondary
  asFreightFor    LandedCostLink[]   @relation("FreightPO")
  freightCostLines FreightCostLine[]

  @@index([supplierId])
  @@index([createdAt])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id              String    @id @default(cuid())
  poId            String
  productId       String
  description     String?   // override product name if needed
  qty             Decimal   @db.Decimal(12, 4) // always in stock units
  purchaseUnitId  String?
  purchaseUnitQty Decimal?  @db.Decimal(12, 4) // qty in purchase units (e.g. 2 boxes)
  unitCostForeign Decimal   @db.Decimal(18, 6)  // effective net cost per stock unit (post-discount, post-VAT extraction)
  unitCostBase     Decimal   @db.Decimal(18, 6)  // effective net cost per stock unit in GBP
  discountStr     String?   // e.g. "5%" or "2.50" — original user input (display only)
  discountAmount  Decimal   @db.Decimal(18, 4) @default(0) // line discount amount in foreign currency (same inclusive/exclusive convention as the user-entered unit cost)
  taxRateId       String?
  taxForeign      Decimal   @db.Decimal(18, 4) @default(0)
  taxBase          Decimal   @db.Decimal(18, 4) @default(0)
  totalForeign    Decimal   @db.Decimal(18, 4) // net of discount and VAT
  totalBase        Decimal   @db.Decimal(18, 4) // net of discount and VAT
  landedUnitCostBase Decimal @db.Decimal(18, 6) @default(0) // set after landed cost allocation
  qtyReceived     Decimal   @db.Decimal(12, 4) @default(0)
  qtyReturned     Decimal   @db.Decimal(12, 4) @default(0)
  sortOrder       Int       @default(0)

  po              PurchaseOrder    @relation(fields: [poId], references: [id])
  product         Product          @relation(fields: [productId], references: [id])
  purchaseUnit    PurchaseUnit?    @relation(fields: [purchaseUnitId], references: [id])
  taxRate         TaxRate?         @relation(fields: [taxRateId], references: [id])
  receiptLines    PurchaseReceiptLine[]
  returnLines     PurchaseReturnLine[]
  invoiceLines    PurchaseInvoiceLine[]
  costLayers      CostLayer[]

  @@index([poId])
  @@index([productId])
  @@map("purchase_order_lines")
}

/// Purchase units — conversion from purchase packaging to stock units
model PurchaseUnit {
  id               String   @id @default(cuid())
  name             String   // e.g. "Box of 100", "Roll (1km)", "Pallet of 48"
  abbreviation     String   // e.g. "box", "roll", "plt"
  conversionFactor Decimal  @db.Decimal(12, 4) // 1 purchase unit = X stock units
  stockUnitName    String   @default("pcs") // what each stock unit is called, e.g. "m", "pcs", "sheets"
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  poLines          PurchaseOrderLine[]

  @@map("purchase_units")
}

/// Links a freight/secondary PO to a primary goods PO for landed cost distribution
model LandedCostLink {
  id              String           @id @default(cuid())
  primaryPoId     String
  freightPoId     String
  method          LandedCostMethod @default(BY_VALUE)
  allocated       Boolean          @default(false) // true once cost has been distributed
  createdAt       DateTime         @default(now())

  primaryPO       PurchaseOrder    @relation("PrimaryPO", fields: [primaryPoId], references: [id])
  freightPO       PurchaseOrder    @relation("FreightPO", fields: [freightPoId], references: [id])

  @@unique([primaryPoId, freightPoId])
  @@map("landed_cost_links")
}

model LandedCostRevaluationRun {
  id             String   @id @default(cuid())
  freightPoId    String?
  primaryPoId    String?
  triggeredById  String?
  status         String
  reason         String?
  beforeJson     Json
  afterJson      Json
  accountingJson Json?
  warningsJson   Json?
  createdAt      DateTime @default(now())

  @@index([freightPoId, createdAt])
  @@index([primaryPoId, createdAt])
  @@index([status, createdAt])
  @@map("landed_cost_revaluation_runs")
}

/// Individual cost line items on a FREIGHT-type PO
model FreightCostLine {
  id                 String           @id @default(cuid())
  poId               String
  description        String
  amountForeign      Decimal          @db.Decimal(18, 4)
  amountBase          Decimal          @db.Decimal(18, 4)
  vatable            Boolean          @default(false)
  distributionMethod LandedCostMethod @default(BY_VALUE)
  sortOrder          Int              @default(0)

  po                 PurchaseOrder    @relation(fields: [poId], references: [id])
  invoiceLines       PurchaseInvoiceLine[]

  @@map("freight_cost_lines")
}

model PurchaseReceipt {
  id          String    @id @default(cuid())
  poId        String
  reference   String?
  externalKey String?   @unique
  receivedAt  DateTime  @default(now())
  notes       String?
  createdAt   DateTime  @default(now())

  po          PurchaseOrder        @relation(fields: [poId], references: [id])
  lines       PurchaseReceiptLine[]

  @@map("purchase_receipts")
}

model PurchaseReceiptLine {
  id                   String    @id @default(cuid())
  receiptId            String
  poLineId             String
  qtyReceived          Decimal   @db.Decimal(12, 4)
  coveredBySnapshotQty Decimal   @db.Decimal(12, 4) @default(0)
  warehouseId          String?   // warehouse goods were received into

  receipt     PurchaseReceipt   @relation(fields: [receiptId], references: [id])
  poLine      PurchaseOrderLine @relation(fields: [poLineId], references: [id])

  @@index([receiptId])
  @@index([poLineId])
  @@map("purchase_receipt_lines")
}

model PurchaseInvoice {
  id              String    @id @default(cuid())
  poId            String
  invoiceNumber   String?
  invoiceDate     DateTime
  dueDate         DateTime?
  subtotalForeign Decimal   @db.Decimal(18, 4) @default(0)
  subtotalBase     Decimal   @db.Decimal(18, 4) @default(0)
  taxForeign      Decimal   @db.Decimal(18, 4) @default(0)
  taxBase          Decimal   @db.Decimal(18, 4) @default(0)
  totalForeign    Decimal   @db.Decimal(18, 4)
  totalBase        Decimal   @db.Decimal(18, 4)
  fxRateToBase     Decimal   @db.Decimal(18, 8)
  notes           String?
  supplierInvoiceUrl String? // path to uploaded supplier PDF
  accountingInvoiceId String?  @map("accounting_invoice_id")
  paidAt          DateTime?
  paymentAccountId   String?   // connector account id (e.g. Xero bank AccountID) used to pay this bill
  paymentAccountName String?   // snapshot of the bank account name at payment time
  paymentReference   String?   // optional user-entered payment reference
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  po              PurchaseOrder @relation(fields: [poId], references: [id])
  lines           PurchaseInvoiceLine[]

  @@index([poId])
  @@map("purchase_invoices")
}

model PurchaseInvoiceLine {
  id              String    @id @default(cuid())
  invoiceId       String
  poLineId        String?
  costLineId      String?
  description     String?
  qtyBilled       Decimal   @db.Decimal(12, 4)
  unitCostForeign Decimal   @db.Decimal(18, 6)
  totalForeign    Decimal   @db.Decimal(18, 4)
  totalBase        Decimal   @db.Decimal(18, 4)

  invoice         PurchaseInvoice    @relation(fields: [invoiceId], references: [id])
  poLine          PurchaseOrderLine? @relation(fields: [poLineId], references: [id])
  costLine        FreightCostLine?   @relation(fields: [costLineId], references: [id])

  @@index([invoiceId])
  @@index([poLineId])
  @@index([costLineId])
  @@map("purchase_invoice_lines")
}

model PurchaseReturn {
  id          String    @id @default(cuid())
  poId        String
  reference   String?
  returnedAt  DateTime  @default(now())
  reason      String?
  notes       String?
  createdAt   DateTime  @default(now())

  po          PurchaseOrder      @relation(fields: [poId], references: [id])
  lines       PurchaseReturnLine[]

  @@map("purchase_returns")
}

model PurchaseReturnLine {
  id          String    @id @default(cuid())
  returnId    String
  poLineId    String
  qtyReturned Decimal   @db.Decimal(12, 4)
  warehouseId String?

  return      PurchaseReturn    @relation(fields: [returnId], references: [id])
  poLine      PurchaseOrderLine @relation(fields: [poLineId], references: [id])

  @@index([returnId])
  @@index([poLineId])
  @@map("purchase_return_lines")
}

// ---------------------------------------------------------------------------
// CUSTOMERS
// ---------------------------------------------------------------------------

model Customer {
  id              String    @id @default(cuid())
  firstName       String
  lastName        String
  accountingContactId String?   @unique
  email           String?
  phone           String?
  company         String?
  taxNumber       String?   // VAT / tax ID
  billingAddress  Json?     // { line1, line2, city, county, postcode, country }
  shippingAddress Json?     // { line1, line2, city, county, postcode, country }
  notes           String?
  externalCustomerId Int?    @unique // Shopping connector customer ID
  active          Boolean   @default(true)
  archived        Boolean   @default(false)
  gdprAnonymisedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  salesOrders     SalesOrder[]
  shoppingLinks   ShoppingCustomerLink[]

  @@map("customers")
}

// SALES ORDERS
// ---------------------------------------------------------------------------

model SalesOrder {
  id                String           @id @default(cuid())
  externalOrderNumber String?         // Storefront order number/reference
  status            SalesOrderStatus @default(DRAFT)
  currency          String           @default("GBP")
  fxRateToBase       Decimal          @db.Decimal(18, 8) @default(1)

  // Customer
  customerId        String?
  customerName      String?
  customerEmail     String?
  billingAddress    Json?
  shippingAddress   Json?

  // Totals (in order currency)
  subtotalForeign   Decimal          @db.Decimal(18, 4)
  shippingService   String?          // e.g. "Royal Mail", "DPD Next Day"
  shippingForeign   Decimal          @db.Decimal(18, 4) @default(0)
  taxRateName       String?          // e.g. "UK Standard Rate"
  taxRatePercent    Decimal?         @db.Decimal(5, 4) // e.g. 0.2000
  taxForeign        Decimal          @db.Decimal(18, 4) @default(0)
  pricesIncludeVat  Boolean          @default(false) // true when unit prices are tax-inclusive (display as gross)
  totalForeign      Decimal          @db.Decimal(18, 4)

  // Totals in GBP
  subtotalBase       Decimal          @db.Decimal(18, 4)
  shippingBase       Decimal          @db.Decimal(18, 4) @default(0)
  taxBase            Decimal          @db.Decimal(18, 4) @default(0)
  totalBase          Decimal          @db.Decimal(18, 4)

  // Fulfilment
  shipFromWarehouseId String?
  expectedDelivery  DateTime?
  salesRep          String?
  shippedAt         DateTime?
  trackingNumber    String?
  discountStr       String?    // order-level discount input e.g. "10%" or "5.00"
  discountAmount    Decimal    @db.Decimal(18, 4) @default(0) // computed order discount in foreign currency
  invoiceNumber     String?    // generated invoice reference
  invoicedAt        DateTime?
  paymentDueAt      DateTime?
  accountingInvoiceId     String?    @map("accounting_invoice_id") // Accounting invoice ID after sync
  paidAt            DateTime?
  orderNumber       String?    // IMS order number (prefix + WC number, or manual)
  paymentMethod     String?    // e.g. "stripe", "paypal", "bacs" — populated by any shopping channel
  paymentMethodTitle String?   // e.g. "Credit card", "PayPal"
  invoicePdfPath    String?    // path to saved invoice PDF (generic, set by any accounting module)

  // Accounting sub-ledger tracking
  revenueDeferredDate    DateTime?              @map("accounting_revenue_deferred_date") // Set by Group A1 — revenue deferred to Unearned
  unearnedRevenueAmount  Decimal?  @db.Decimal(18, 4) @map("accounting_unearned_revenue_amount") // Amount deferred
  inventoryAllocatedDate DateTime?              @map("accounting_inventory_allocated_date") // Set by Group A2 — inventory reclassified to Allocated
  allocationBatchAmount  Decimal?  @db.Decimal(18, 4) @map("accounting_allocation_batch_amount") // Cost value reclassified

  notes             String?     // customer-visible notes
  internalNotes     String?     // private/staff notes

  externalCreatedAt DateTime?        // order date in shopping connector
  externalUpdatedAt DateTime?
  archived          Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  customer          Customer?        @relation(fields: [customerId], references: [id])
  shipFromWarehouse Warehouse?       @relation("ShipFromWarehouse", fields: [shipFromWarehouseId], references: [id])
  lines             SalesOrderLine[]
  refunds           SalesOrderRefund[]
  payments          Payment[]
  allocations       OrderAllocation[]
  shipments         Shipment[]
  shoppingLinks     ShoppingOrderLink[]
  wmsReturnsInbox   WmsReturnsInbox[] @relation("WmsReturnsInboxOrder")

  @@index([status])
  @@index([status, updatedAt(sort: Desc)], map: "sales_orders_status_updatedAt_idx")
  @@index([createdAt])
  @@map("sales_orders")
}

model SalesOrderLine {
  id              String     @id @default(cuid())
  orderId         String
  productId       String?    // null if product deleted / not found
  externalLineItemId Int?
  description     String
  sku             String?
  qty             Decimal    @db.Decimal(12, 4)
  unitPriceForeign Decimal   @db.Decimal(18, 6)  // original price before discount
  unitPriceBase    Decimal    @db.Decimal(18, 6)
  discountStr     String?    // e.g. "5%" or "2.50" — original user input
  discountAmount  Decimal    @db.Decimal(18, 4) @default(0) // computed line discount amount in foreign currency
  taxRateId       String?
  taxForeign      Decimal    @db.Decimal(18, 4) @default(0)
  taxBase          Decimal    @db.Decimal(18, 4) @default(0)
  totalForeign    Decimal    @db.Decimal(18, 4)
  totalBase        Decimal    @db.Decimal(18, 4)
  cogsBase         Decimal?   @db.Decimal(18, 4) // set on dispatch

  order           SalesOrder @relation(fields: [orderId], references: [id])
  product         Product?   @relation(fields: [productId], references: [id])
  taxRate         TaxRate?   @relation(fields: [taxRateId], references: [id])
  allocations     OrderAllocation[]
  shipmentLines   ShipmentLine[]
  refundLines     SalesOrderRefundLine[]

  @@index([orderId])
  @@index([productId])
  @@map("sales_order_lines")
}

model SalesOrderRefund {
  id              String     @id @default(cuid())
  orderId         String
  creditNoteNumber String?   // e.g. "CN-2025-00001"
  accountingCreditNoteId String?   @map("accounting_credit_note_id") // Accounting credit note ID after sync
  externalRefundId Int?
  returnWarehouseId String?
  reason          String?
  totalForeign    Decimal    @db.Decimal(18, 4)
  totalBase        Decimal    @db.Decimal(18, 4)
  accountingRetryRequired Boolean @default(false) @map("accounting_retry_required")
  accountingWarning String?   @map("accounting_warning")
  accountingRetrySyncs Json?  @map("accounting_retry_syncs")
  refundedAt      DateTime   @default(now())
  createdAt       DateTime   @default(now())

  order           SalesOrder @relation(fields: [orderId], references: [id])
  returnWarehouse Warehouse? @relation(fields: [returnWarehouseId], references: [id])
  lines           SalesOrderRefundLine[]
  payments        Payment[]

  @@unique([externalRefundId])
  @@index([orderId])
  @@map("sales_order_refunds")
}

model SalesOrderRefundLine {
  id              String           @id @default(cuid())
  refundId        String
  salesOrderLineId String?         @map("sales_order_line_id")
  productId       String?
  description     String
  qty             Decimal          @db.Decimal(12, 4)
  unitPriceForeign Decimal         @db.Decimal(18, 6) @default(0)
  unitPriceBase    Decimal          @db.Decimal(18, 6)
  totalForeign     Decimal          @db.Decimal(18, 4) @default(0)
  totalBase        Decimal          @db.Decimal(18, 4)
  costLayerSnapshot Json?

  refund          SalesOrderRefund @relation(fields: [refundId], references: [id])
  salesOrderLine  SalesOrderLine?  @relation(fields: [salesOrderLineId], references: [id], onDelete: SetNull)
  product         Product?         @relation(fields: [productId], references: [id])

  @@index([refundId])
  @@index([salesOrderLineId], map: "sales_order_refund_lines_sales_order_line_id_idx")
  @@index([productId])
  @@index([costLayerSnapshot(ops: JsonbOps)], type: Gin, map: "sales_order_refund_lines_costLayerSnapshot_gin_idx")
  @@map("sales_order_refund_lines")
}

/// Payments recorded against sales orders (invoices) or credit notes (refunds)
model Payment {
  id              String    @id @default(cuid())
  orderId         String
  refundId        String?   // null = payment against invoice, set = payment against credit note
  amount          Decimal   @db.Decimal(18, 4) // positive for receipts, negative for credit note payments
  currency        String    @default("GBP")
  method          String?   // e.g. "Bank Transfer", "Card", "Cash", "PayPal"
  reference       String?   // payment ref / transaction ID
  notes           String?
  paidAt          DateTime  @default(now())
  createdAt       DateTime  @default(now())

  order           SalesOrder       @relation(fields: [orderId], references: [id])
  refund          SalesOrderRefund? @relation(fields: [refundId], references: [id])

  @@index([orderId])
  @@index([refundId])
  @@map("payments")
}

// ---------------------------------------------------------------------------
// STOCK CONTROL
// ---------------------------------------------------------------------------

model StockTransfer {
  id              String              @id @default(cuid())
  reference       String              @unique
  fromWarehouseId String
  toWarehouseId   String
  status          StockTransferStatus @default(DRAFT)
  notes           String?
  dispatchedAt    DateTime?
  completedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  fromWarehouse   Warehouse           @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse           @relation("TransferTo", fields: [toWarehouseId], references: [id])
  lines           StockTransferLine[]

  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@map("stock_transfers")
}

model StockTransferLine {
  id                String        @id @default(cuid())
  transferId        String
  productId         String        // stored directly (no FK to Product to allow orphaned lines in audit)
  sku               String
  productName       String        @default("")
  qty               Decimal       @db.Decimal(12, 4)
  qtyReceived       Decimal       @db.Decimal(12, 4) @default(0)
  costLayerSnapshot Json?         // FIFO layers consumed at dispatch — used to recreate at destination on receipt

  transfer          StockTransfer @relation(fields: [transferId], references: [id])

  @@index([transferId])
  @@index([costLayerSnapshot(ops: JsonbOps)], type: Gin, map: "stock_transfer_lines_costLayerSnapshot_gin_idx")
  @@map("stock_transfer_lines")
}

model StockCount {
  id          String           @id @default(cuid())
  reference   String           @unique
  warehouseId String
  status      StockCountStatus @default(DRAFT)
  notes       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])
  lines       StockCountLine[]

  @@index([warehouseId])
  @@map("stock_counts")
}

model StockCountLine {
  id              String     @id @default(cuid())
  countId         String
  productId       String
  sku             String
  expectedQty     Decimal    @db.Decimal(12, 4)
  countedQty      Decimal?   @db.Decimal(12, 4) // null = not yet counted
  variance        Decimal?   @db.Decimal(12, 4) // countedQty - expectedQty
  notes           String?

  count           StockCount @relation(fields: [countId], references: [id])

  @@index([countId])
  @@index([productId])
  @@map("stock_count_lines")
}

// ---------------------------------------------------------------------------
// MANUFACTURING
// ---------------------------------------------------------------------------

/// Bill of Materials — one BOM per finished product
model Bom {
  id          String    @id @default(cuid())
  name        String
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items       BomItem[]
  productionOrders ProductionOrder[]

  @@map("boms")
}

model BomItem {
  id            String  @id @default(cuid())
  bomId         String
  parentProductId String // the finished good produced
  componentProductId String
  qty           Decimal @db.Decimal(12, 4)
  notes         String?
  sortOrder     Int     @default(0)

  bom           Bom     @relation(fields: [bomId], references: [id])
  parentProduct Product @relation("BomParent", fields: [parentProductId], references: [id])
  component     Product @relation("BomComponent", fields: [componentProductId], references: [id])

  @@index([bomId])
  @@index([parentProductId])
  @@index([componentProductId])
  @@map("bom_items")
}

/// Virtual kit — not physically assembled; components deducted on sale
model Kit {
  id          String    @id @default(cuid())
  name        String
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items       KitItem[]

  @@map("kits")
}

model KitItem {
  id              String  @id @default(cuid())
  kitId           String
  parentProductId String  // the kit product SKU
  componentProductId String
  qty             Decimal @db.Decimal(12, 4)
  sortOrder       Int     @default(0)

  kit             Kit     @relation(fields: [kitId], references: [id])
  parentProduct   Product @relation("KitParent", fields: [parentProductId], references: [id])
  component       Product @relation("KitItemComponent", fields: [componentProductId], references: [id])

  @@index([kitId])
  @@index([parentProductId])
  @@index([componentProductId])
  @@map("kit_items")
}

model ProductionOrder {
  id              String                @id @default(cuid())
  reference       String                @unique
  orderType       ProductionOrderType   @default(ASSEMBLY)
  bomId           String
  outputProductId String               // finished good
  warehouseId     String               // produced in / stock added to
  manufacturerId  String?              // optional: supplier acting as manufacturer
  qtyPlanned      Decimal              @db.Decimal(12, 4)
  qtyProduced     Decimal              @db.Decimal(12, 4) @default(0)
  status          ProductionOrderStatus @default(DRAFT)
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  // Order currency + FX for foreign-currency manufacturing costs (labour
  // priced in a non-base currency, etc.). Base totals on cost lines use
  // this rate. Defaults to base currency / 1.0.
  currency        String               @default("GBP")
  fxRateToBase    Decimal              @db.Decimal(18, 8) @default(1)

  bom             Bom                  @relation(fields: [bomId], references: [id])
  outputProduct   Product              @relation(fields: [outputProductId], references: [id])
  warehouse       Warehouse            @relation(fields: [warehouseId], references: [id])
  manufacturer    Supplier?            @relation(fields: [manufacturerId], references: [id])
  manufacturingCostLines ManufacturingCostLine[]
  costLayers      CostLayer[]

  @@index([status])
  @@index([createdAt])
  @@map("production_orders")
}

/// Per-run overheads applied to a production order (labour, machine time,
/// utilities, etc.). Sum is spread equally across qtyProduced and folded
/// into the output cost layer on assembly (or the recovered-component
/// layers on disassembly). Each line optionally overrides the default
/// manufacturing-overhead account from Settings.
model ManufacturingCostLine {
  id                String   @id @default(cuid())
  productionOrderId String
  description       String
  amountForeign     Decimal  @db.Decimal(18, 4)
  amountBase        Decimal  @db.Decimal(18, 4)
  accountCode       String?
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  @@index([productionOrderId])
  @@map("manufacturing_cost_lines")
}

