// XERO SYNC
// ---------------------------------------------------------------------------

model AccountingAccount {
  id                String   @id @default(cuid())
  connector         String   @default("xero")
  externalAccountId String   // Connector account ID
  code              String?
  name              String
  type              String   // EXPENSE, REVENUE, ASSET, etc.
  taxType           String?
  active            Boolean  @default(true)
  syncedAt          DateTime @default(now())

  @@unique([connector, externalAccountId])
  @@index([connector, active, code])
  @@map("accounting_accounts")
}

model AccountingAccountBalanceSnapshot {
  id                String   @id @default(cuid())
  connector         String   @default("xero")
  externalAccountId String
  accountCode       String?
  accountName       String
  balanceDate       DateTime @db.Date
  currency          String
  amountForeign     Decimal  @db.Decimal(18, 6)
  amountBase        Decimal  @db.Decimal(18, 6)
  sourcePayloadRef  String?
  syncRunId         String?
  fetchedAt         DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  @@unique([connector, externalAccountId, balanceDate, currency], map: "accounting_account_balance_snapshots_connector_externalAcco_key")
  @@index([connector, accountCode, balanceDate], map: "accounting_account_balance_snapshots_connector_accountCode__idx")
  @@index([connector, balanceDate])
  @@map("accounting_account_balance_snapshots")
}

model AccountingSyncLog {
  id                    String               @id @default(cuid())
  connector             String               @default("xero")
  type                  AccountingSyncType
  status                AccountingSyncStatus @default(PENDING)
  referenceType         String // "PurchaseOrder", "CogsEntry", "SalesOrder", etc.
  referenceId           String
  externalTransactionId String?
  payload               Json? // what was sent
  errorMessage          String?
  retryCount            Int                  @default(0)
  processingStartedAt   DateTime?
  syncedAt              DateTime?
  createdAt             DateTime             @default(now())

  // Polymorphic reference: use referenceType + referenceId for application-level lookups.
  // No FK constraints — referenceId may point to PurchaseOrder, SalesOrder, etc. based on referenceType.

  @@index([connector, referenceType, referenceId])
  @@index([connector, status, createdAt])
  @@index([connector, status, processingStartedAt])
  @@map("accounting_sync_logs")
}

model AccountingEvent {
  id               String   @id @default(cuid())
  type             String
  sourceEntityType String
  sourceEntityId   String
  businessDate     DateTime
  status           String   @default("PENDING")
  idempotencyKey   String   @unique
  linesJson        Json
  currency         String
  externalSystem   String?
  externalId       String?
  reversalOfId     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  reversalOf       AccountingEvent?  @relation("AccountingEventReversal", fields: [reversalOfId], references: [id])
  reversals        AccountingEvent[] @relation("AccountingEventReversal")
  logs             AccountingEventLog[]

  @@index([sourceEntityType, sourceEntityId])
  @@index([status, businessDate])
  @@unique([externalSystem, externalId])
  @@index([reversalOfId])
  @@map("accounting_events")
}

model AccountingEventLog {
  id                String   @id @default(cuid())
  accountingEventId String
  action            String
  message           String?
  metadata          Json?
  createdAt         DateTime @default(now())

  accountingEvent   AccountingEvent @relation(fields: [accountingEventId], references: [id], onDelete: Cascade)

  @@index([accountingEventId, createdAt])
  @@map("accounting_event_logs")
}

model AccountingReconciliationRun {
  id            String   @id @default(cuid())
  fromDate      DateTime?
  toDate        DateTime?
  status        String
  totalCount    Int
  warningCount  Int
  criticalCount Int
  createdAt     DateTime @default(now())

  findings      AccountingReconciliationFinding[]

  @@index([status, createdAt])
  @@index([createdAt])
  @@map("accounting_reconciliation_runs")
}

model AccountingReconciliationFinding {
  id              String    @id @default(cuid())
  runId           String
  severity        String
  code            String
  entityType      String?
  entityId        String?
  message         String
  details         Json
  status          String    @default("OPEN")
  /// Latest review-state actor/time for fast admin lists. Full status-change
  /// history is written to ActivityLog as AccountingReconciliationFinding rows.
  statusUpdatedAt DateTime?
  statusUpdatedBy String?
  createdAt       DateTime  @default(now())

  run        AccountingReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, status])
  @@index([status, createdAt])
  @@index([code, status])
  @@index([entityType, entityId])
  @@map("accounting_reconciliation_findings")
}

model AccountingToken {
  id           String   @id @default(cuid())
  connector    String   @default("xero")
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  tenantId     String
  tenantName   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([connector])
  @@unique([connector, tenantId])
  @@map("accounting_tokens")
}

